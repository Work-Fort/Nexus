post_install() {
    setcap cap_sys_admin+ep usr/bin/nexus-netns
    setcap cap_net_admin,cap_net_raw,cap_sys_admin+ep usr/bin/nexus-cni-exec
    setcap cap_sys_admin+ep usr/bin/nexus-quota
    setcap cap_sys_admin,cap_fowner+ep usr/bin/nexus-btrfs
    setcap cap_net_bind_service+ep usr/bin/nexus-dns
}

post_upgrade() {
    post_install
}
