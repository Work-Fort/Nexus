#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
#MISE description="Test AUR package build locally"
set -euo pipefail

cd aur

cp PKGBUILD PKGBUILD.bak
trap 'mv PKGBUILD.bak PKGBUILD' EXIT
cat > PKGBUILD << 'PKGBUILD_EOF'
# LOCAL TEST BUILD — generated by mise run aur:test
source PKGBUILD.bak

source=()
sha256sums=()

_projroot="${startdir}/.."

build() {
    cd "$_projroot"
    export CGO_ENABLED=0
    LDFLAGS="-s -w -X github.com/Work-Fort/Nexus/cmd.Version=v${pkgver}"
    go build -ldflags "${LDFLAGS}" -o "$srcdir/nexus"
    go build -ldflags "${LDFLAGS}" -o "$srcdir/nexusctl" ./cmd/nexusctl/
    go build -ldflags "-s -w" -o "$srcdir/nexus-netns" ./cmd/nexus-netns/
    go build -ldflags "-s -w" -o "$srcdir/nexus-cni-exec" ./cmd/nexus-cni-exec/
    go build -ldflags "-s -w" -o "$srcdir/nexus-quota" ./cmd/nexus-quota/
    go build -ldflags "-s -w" -o "$srcdir/nexus-btrfs" ./cmd/nexus-btrfs/
    go build -ldflags "-s -w" -o "$srcdir/nexus-dns" ./cmd/nexus-dns/
}

package() {
    install -Dm755 "$srcdir/nexus" "${pkgdir}/usr/bin/nexus"
    install -Dm755 "$srcdir/nexusctl" "${pkgdir}/usr/bin/nexusctl"
    install -Dm755 "$srcdir/nexus-netns" "${pkgdir}/usr/bin/nexus-netns"
    install -Dm755 "$srcdir/nexus-cni-exec" "${pkgdir}/usr/bin/nexus-cni-exec"
    install -Dm755 "$srcdir/nexus-quota" "${pkgdir}/usr/bin/nexus-quota"
    install -Dm755 "$srcdir/nexus-btrfs" "${pkgdir}/usr/bin/nexus-btrfs"
    install -Dm755 "$srcdir/nexus-dns" "${pkgdir}/usr/bin/nexus-dns"
    install -Dm644 "$_projroot/dist/nexus.service" "${pkgdir}/usr/lib/systemd/user/nexus.service"
    install -Dm755 "${srcdir}/node_exporter-${_node_exporter_ver}.linux-"*/node_exporter "${pkgdir}/usr/bin/node_exporter"

    # Download Anvil kernel from release.
    install -dm755 "${pkgdir}/usr/share/nexus"
    local _kernel_url="https://github.com/Work-Fort/Anvil/releases/download/v${_anvil_kernel_ver}"
    if [[ "$(uname -m)" == "x86_64" ]]; then
        curl -fsSL "${_kernel_url}/vmlinux-${_anvil_kernel_ver}-x86_64.xz" | xz -d > "${pkgdir}/usr/share/nexus/vmlinux"
    else
        curl -fsSL "${_kernel_url}/Image-${_anvil_kernel_ver}-aarch64.xz" | xz -d > "${pkgdir}/usr/share/nexus/vmlinux"
    fi
    chmod 644 "${pkgdir}/usr/share/nexus/vmlinux"
    install -Dm644 "$_projroot/dist/kata-configuration.toml" "${pkgdir}/etc/kata-containers/configuration.toml"
}
PKGBUILD_EOF

makepkg -sf --noconfirm
echo ""
echo "Package contents:"
pacman -Qlp *.pkg.tar.zst | grep -v debug
echo ""
echo "Dependencies:"
pacman -Qip *.pkg.tar.zst | grep "Depends On"
echo ""
echo "Install script:"
pacman -Qip *.pkg.tar.zst | grep "Install Script"
rm -f *.pkg.tar.zst
rm -rf src/ pkg/
echo "✓ AUR test build complete"
